# ──────────────────────────────────────────────────────────────────────────
# Firebase — shared media library + brand AI context (NEXT_PUBLIC_* = client)
# Values are inlined into the client bundle at `next build`. On Docker/Railway
# they must also be available as build args (see Dockerfile + docs/deployment.md).
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ──────────────────────────────────────────────────────────────────────────
# Gemini — server-side only. Must NOT be prefixed NEXT_PUBLIC_* or it would
# leak into every visitor's browser bundle. Read by `src/app/api/gemini/route.ts`.
# Get one at https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Optional — force-enable export on serverless hosts (Vercel/Netlify). Leave
# unset unless you know your host can run Chrome + FFmpeg inside a function.
# ──────────────────────────────────────────────────────────────────────────
# REMOTION_ALLOW_EXPORT_ON_SERVERLESS=1
